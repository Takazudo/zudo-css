---
import "../styles/tokens.css";
import SidebarNav from "../components/sidebar-nav.tsx";
import ColorTweakPanel from "../components/color-tweak-panel.tsx";
import AiChatModal from "../components/ai-chat-modal.tsx";

interface Props {
  title: string;
  activeCategory?: string;
}

const { title, activeCategory } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — CSS Playground</title>
  </head>
  <body class="min-h-screen">
    <div class="flex min-h-screen">
      <aside class="w-[250px] shrink-0 bg-surface border-r border-r-muted/20 p-vsp-md">
        <div class="mb-vsp-lg">
          <a href="/" class="text-subheading font-bold text-accent no-underline">
            CSS Playground
          </a>
        </div>
        <SidebarNav client:load activeCategory={activeCategory} />
        <div class="mt-vsp-lg pt-vsp-sm border-t border-muted/20">
          <button
            onclick="window.dispatchEvent(new Event('toggle-ai-chat'))"
            class="w-full px-hsp-sm py-vsp-2xs rounded text-small text-muted hover:text-accent hover:bg-accent/10 transition-colors cursor-pointer border border-muted/20 bg-transparent text-left"
          >
            AI Chat
          </button>
        </div>
      </aside>
      <main class="flex-1 p-vsp-xl overflow-auto">
        <slot />
      </main>
    </div>
    <ColorTweakPanel client:load />
    <AiChatModal client:load />
  </body>
</html>
