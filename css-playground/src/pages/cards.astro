---
import BaseLayout from "../layouts/base-layout.astro";
import HtmlPreview from "../components/html-preview.tsx";
---

<BaseLayout title="Cards" activeCategory="cards">
  <h1 class="text-heading font-bold mb-vsp-lg">Card Patterns</h1>
  <p class="text-body text-muted mb-vsp-xl">
    8 card layout patterns using tight tokens.
  </p>

  <div class="space-y-vsp-xl">
    <section>
      <h2 class="text-subheading font-semibold mb-vsp-sm">
        1. Simple Content Card
      </h2>
      <HtmlPreview
        client:load
        title="Simple Content Card"
        html={`<div style="max-width:320px; background:#313244; border-radius:0.5rem; border:1px solid rgba(108,112,134,0.3); overflow:hidden;">
  <div style="height:160px; background:linear-gradient(135deg, #89b4fa 0%, #f5c2e7 100%);"></div>
  <div style="padding:1rem;">
    <h3 style="font-size:1.125rem; font-weight:600; color:#cdd6f4; margin-bottom:0.5rem;">Card Title</h3>
    <p style="font-size:0.875rem; color:#6c7086; line-height:1.5;">A brief description of the card content goes here. Keep it concise and informative.</p>
  </div>
</div>`}
        css={``}
        height={300}
      />
    </section>

    <section>
      <h2 class="text-subheading font-semibold mb-vsp-sm">
        2. Horizontal Card
      </h2>
      <HtmlPreview
        client:load
        title="Horizontal Card"
        html={`<div style="display:flex; max-width:480px; background:#313244; border-radius:0.5rem; border:1px solid rgba(108,112,134,0.3); overflow:hidden;">
  <div style="width:140px; min-height:120px; background:linear-gradient(135deg, #a6e3a1 0%, #94e2d5 100%); flex-shrink:0;"></div>
  <div style="padding:1rem; display:flex; flex-direction:column; justify-content:center;">
    <h3 style="font-size:1.125rem; font-weight:600; color:#cdd6f4; margin-bottom:0.25rem;">Horizontal Card</h3>
    <p style="font-size:0.875rem; color:#6c7086; line-height:1.5; margin-bottom:0.75rem;">Side-by-side layout with image and text content.</p>
    <a href="#" style="font-size:0.875rem; color:#89b4fa; text-decoration:none;">Learn more →</a>
  </div>
</div>`}
        css={``}
        height={140}
      />
    </section>
  </div>
</BaseLayout>
