---
import BaseLayout from '../layouts/base-layout.astro';
import HtmlPreview from '../components/html-preview.tsx';
---

<BaseLayout title="Cards" activeCategory="cards">
  <h1 class="text-heading font-bold mb-vsp-lg">Card Patterns</h1>
  <p class="text-body text-muted mb-vsp-xl">8 card variations built with strict design tokens.</p>

  <div class="space-y-vsp-xl">
    <section>
      <h2 class="text-subheading font-semibold mb-vsp-sm">1. Simple Card</h2>
      <HtmlPreview
        client:visible
        title="Simple Card"
        html={`<div class="card-1">
  <h3 class="card-1__title">Card Title</h3>
  <p class="card-1__body">This is a simple card with a title, body text, and an action button. It demonstrates the most basic card pattern.</p>
  <a href="#" class="card-1__action">Learn More</a>
</div>`}
        css={`* { margin: 0; padding: 0; box-sizing: border-box; }
body { background: var(--bg-subtle); padding: var(--space-md); font-family: system-ui, sans-serif; }

.card-1 {
  background: var(--bg);
  border-radius: var(--radius);
  padding: var(--space-lg);
  box-shadow: 0 1px 3px hsl(220 25% 15% / 0.1);
  max-width: 360px;
}

.card-1__title {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--fg);
  margin-bottom: var(--space-sm);
}

.card-1__body {
  font-size: var(--font-md);
  color: var(--fg-muted);
  line-height: 1.5;
  margin-bottom: var(--space-md);
}

.card-1__action {
  font-size: var(--font-sm);
  font-weight: 600;
  color: var(--accent);
  text-decoration: none;
  transition: color 0.2s;
}

.card-1__action:hover {
  color: var(--accent-hover);
}`}
        height={200}
      />
    </section>

    <section>
      <h2 class="text-subheading font-semibold mb-vsp-sm">2. Card with Image Placeholder</h2>
      <HtmlPreview
        client:visible
        title="Card with Image Placeholder"
        html={`<div class="card-2">
  <div class="card-2__image"></div>
  <div class="card-2__content">
    <h3 class="card-2__title">Featured Item</h3>
    <p class="card-2__body">A card with a colored placeholder area representing an image or media content.</p>
    <a href="#" class="card-2__action">View Details</a>
  </div>
</div>`}
        css={`* { margin: 0; padding: 0; box-sizing: border-box; }
body { background: var(--bg-subtle); padding: var(--space-md); font-family: system-ui, sans-serif; }

.card-2 {
  background: var(--bg);
  border-radius: var(--radius);
  overflow: hidden;
  box-shadow: 0 1px 3px hsl(220 25% 15% / 0.1);
  max-width: 360px;
}

.card-2__image {
  height: 160px;
  background: linear-gradient(135deg, var(--accent), var(--accent-hover));
}

.card-2__content {
  padding: var(--space-md);
}

.card-2__title {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--fg);
  margin-bottom: var(--space-xs);
}

.card-2__body {
  font-size: var(--font-md);
  color: var(--fg-muted);
  line-height: 1.5;
  margin-bottom: var(--space-md);
}

.card-2__action {
  font-size: var(--font-sm);
  font-weight: 600;
  color: var(--accent);
  text-decoration: none;
  transition: color 0.2s;
}

.card-2__action:hover {
  color: var(--accent-hover);
}`}
        height={320}
      />
    </section>

    <section>
      <h2 class="text-subheading font-semibold mb-vsp-sm">3. Horizontal Card</h2>
      <HtmlPreview
        client:visible
        title="Horizontal Card"
        html={`<div class="card-3">
  <div class="card-3__image"></div>
  <div class="card-3__content">
    <h3 class="card-3__title">Horizontal Layout</h3>
    <p class="card-3__body">Image on the left, content on the right. Great for list-style layouts.</p>
    <a href="#" class="card-3__action">Read More</a>
  </div>
</div>`}
        css={`* { margin: 0; padding: 0; box-sizing: border-box; }
body { background: var(--bg-subtle); padding: var(--space-md); font-family: system-ui, sans-serif; }

.card-3 {
  display: flex;
  background: var(--bg);
  border-radius: var(--radius);
  overflow: hidden;
  box-shadow: 0 1px 3px hsl(220 25% 15% / 0.1);
  max-width: 520px;
}

.card-3__image {
  width: 180px;
  min-height: 140px;
  flex-shrink: 0;
  background: linear-gradient(135deg, var(--accent), var(--accent-hover));
}

.card-3__content {
  padding: var(--space-md);
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.card-3__title {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--fg);
  margin-bottom: var(--space-xs);
}

.card-3__body {
  font-size: var(--font-md);
  color: var(--fg-muted);
  line-height: 1.5;
  margin-bottom: var(--space-sm);
}

.card-3__action {
  font-size: var(--font-sm);
  font-weight: 600;
  color: var(--accent);
  text-decoration: none;
  transition: color 0.2s;
}

.card-3__action:hover {
  color: var(--accent-hover);
}`}
        height={180}
      />
    </section>

    <section>
      <h2 class="text-subheading font-semibold mb-vsp-sm">4. Card with Tags</h2>
      <HtmlPreview
        client:visible
        title="Card with Tags"
        html={`<div class="card-4">
  <div class="card-4__tags">
    <span class="card-4__tag">Design</span>
    <span class="card-4__tag">CSS</span>
    <span class="card-4__tag card-4__tag--accent">New</span>
  </div>
  <h3 class="card-4__title">Tagged Content</h3>
  <p class="card-4__body">Cards with badges and tags help users quickly identify content categories and status.</p>
</div>`}
        css={`* { margin: 0; padding: 0; box-sizing: border-box; }
body { background: var(--bg-subtle); padding: var(--space-md); font-family: system-ui, sans-serif; }

.card-4 {
  background: var(--bg);
  border-radius: var(--radius);
  padding: var(--space-lg);
  box-shadow: 0 1px 3px hsl(220 25% 15% / 0.1);
  max-width: 360px;
}

.card-4__tags {
  display: flex;
  gap: var(--space-xs);
  margin-bottom: var(--space-sm);
}

.card-4__tag {
  font-size: var(--font-sm);
  color: var(--fg-muted);
  background: var(--bg-subtle);
  padding: 0 var(--space-xs);
  border-radius: 4px;
  font-weight: 500;
}

.card-4__tag--accent {
  color: var(--bg);
  background: var(--accent);
  font-weight: 600;
}

.card-4__title {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--fg);
  margin-bottom: var(--space-xs);
}

.card-4__body {
  font-size: var(--font-md);
  color: var(--fg-muted);
  line-height: 1.5;
}`}
        height={180}
      />
    </section>

    <section>
      <h2 class="text-subheading font-semibold mb-vsp-sm">5. Card with Footer</h2>
      <HtmlPreview
        client:visible
        title="Card with Footer"
        html={`<div class="card-5">
  <div class="card-5__content">
    <h3 class="card-5__title">Article Title</h3>
    <p class="card-5__body">A card with a distinct footer section separated by a divider line, showing metadata like date and author.</p>
  </div>
  <div class="card-5__footer">
    <span class="card-5__meta">Mar 22, 2026</span>
    <span class="card-5__meta">5 min read</span>
  </div>
</div>`}
        css={`* { margin: 0; padding: 0; box-sizing: border-box; }
body { background: var(--bg-subtle); padding: var(--space-md); font-family: system-ui, sans-serif; }

.card-5 {
  background: var(--bg);
  border-radius: var(--radius);
  overflow: hidden;
  box-shadow: 0 1px 3px hsl(220 25% 15% / 0.1);
  max-width: 360px;
}

.card-5__content {
  padding: var(--space-lg);
}

.card-5__title {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--fg);
  margin-bottom: var(--space-xs);
}

.card-5__body {
  font-size: var(--font-md);
  color: var(--fg-muted);
  line-height: 1.5;
}

.card-5__footer {
  display: flex;
  justify-content: space-between;
  padding: var(--space-sm) var(--space-lg);
  border-top: 1px solid var(--border);
  background: var(--bg-subtle);
}

.card-5__meta {
  font-size: var(--font-sm);
  color: var(--fg-muted);
}`}
        height={210}
      />
    </section>

    <section>
      <h2 class="text-subheading font-semibold mb-vsp-sm">6. Outlined Card</h2>
      <HtmlPreview
        client:visible
        title="Outlined Card"
        html={`<div class="card-6">
  <h3 class="card-6__title">Outlined Style</h3>
  <p class="card-6__body">A card using border only with no shadow, creating a lighter visual weight suitable for secondary content.</p>
  <a href="#" class="card-6__action">Explore</a>
</div>`}
        css={`* { margin: 0; padding: 0; box-sizing: border-box; }
body { background: var(--bg); padding: var(--space-md); font-family: system-ui, sans-serif; }

.card-6 {
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: var(--space-lg);
  max-width: 360px;
  transition: border-color 0.2s;
}

.card-6:hover {
  border-color: var(--accent);
}

.card-6__title {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--fg);
  margin-bottom: var(--space-sm);
}

.card-6__body {
  font-size: var(--font-md);
  color: var(--fg-muted);
  line-height: 1.5;
  margin-bottom: var(--space-md);
}

.card-6__action {
  font-size: var(--font-sm);
  font-weight: 600;
  color: var(--accent);
  text-decoration: none;
  transition: color 0.2s;
}

.card-6__action:hover {
  color: var(--accent-hover);
}`}
        height={200}
      />
    </section>

    <section>
      <h2 class="text-subheading font-semibold mb-vsp-sm">7. Filled Accent Card</h2>
      <HtmlPreview
        client:visible
        title="Filled Accent Card"
        html={`<div class="card-7">
  <h3 class="card-7__title">Premium Feature</h3>
  <p class="card-7__body">An accent-colored card with inverted text. Ideal for highlighting important content or calls to action.</p>
  <a href="#" class="card-7__action">Get Started</a>
</div>`}
        css={`* { margin: 0; padding: 0; box-sizing: border-box; }
body { background: var(--bg-subtle); padding: var(--space-md); font-family: system-ui, sans-serif; }

.card-7 {
  background: var(--accent);
  border-radius: var(--radius);
  padding: var(--space-lg);
  max-width: 360px;
}

.card-7__title {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--bg);
  margin-bottom: var(--space-sm);
}

.card-7__body {
  font-size: var(--font-md);
  color: var(--bg);
  line-height: 1.5;
  margin-bottom: var(--space-md);
}

.card-7__action {
  display: inline-block;
  font-size: var(--font-sm);
  font-weight: 600;
  color: var(--accent);
  background: var(--bg);
  padding: var(--space-xs) var(--space-md);
  border-radius: var(--radius);
  text-decoration: none;
  transition: background 0.2s;
}

.card-7__action:hover {
  background: var(--bg-subtle);
}`}
        height={210}
      />
    </section>

    <section>
      <h2 class="text-subheading font-semibold mb-vsp-sm">8. Card Grid</h2>
      <HtmlPreview
        client:visible
        title="Card Grid"
        html={`<div class="card-8-grid">
  <div class="card-8">
    <div class="card-8__icon">&#9733;</div>
    <h3 class="card-8__title">Feature One</h3>
    <p class="card-8__body">Quick description of the first feature.</p>
  </div>
  <div class="card-8">
    <div class="card-8__icon">&#9830;</div>
    <h3 class="card-8__title">Feature Two</h3>
    <p class="card-8__body">Quick description of the second feature.</p>
  </div>
  <div class="card-8">
    <div class="card-8__icon">&#9679;</div>
    <h3 class="card-8__title">Feature Three</h3>
    <p class="card-8__body">Quick description of the third feature.</p>
  </div>
</div>`}
        css={`* { margin: 0; padding: 0; box-sizing: border-box; }
body { background: var(--bg-subtle); padding: var(--space-md); font-family: system-ui, sans-serif; }

.card-8-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: var(--space-md);
}

.card-8 {
  background: var(--bg);
  border-radius: var(--radius);
  padding: var(--space-md);
  box-shadow: 0 1px 3px hsl(220 25% 15% / 0.1);
  text-align: center;
}

.card-8__icon {
  font-size: var(--font-lg);
  color: var(--accent);
  margin-bottom: var(--space-sm);
}

.card-8__title {
  font-size: var(--font-md);
  font-weight: 700;
  color: var(--fg);
  margin-bottom: var(--space-xs);
}

.card-8__body {
  font-size: var(--font-sm);
  color: var(--fg-muted);
  line-height: 1.4;
}`}
        height={200}
      />
    </section>
  </div>
</BaseLayout>
