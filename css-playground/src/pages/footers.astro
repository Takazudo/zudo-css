---
import BaseLayout from '../layouts/base-layout.astro';
import HtmlPreview from '../components/html-preview.tsx';
---

<BaseLayout title="Footers" activeCategory="footers">
  <h1 class="text-heading font-bold mb-vsp-lg">Footer Patterns</h1>
  <p class="text-body text-muted mb-vsp-xl">4 footer variations built with strict design tokens.</p>

  <div class="space-y-vsp-xl">

    <HtmlPreview
      client:visible
      title="1. Simple Centered Footer"
      html={`
<footer class="footer-1">
  <nav class="footer-1__links">
    <a class="footer-1__link" href="#">About</a>
    <span class="footer-1__sep">&middot;</span>
    <a class="footer-1__link" href="#">Privacy</a>
    <span class="footer-1__sep">&middot;</span>
    <a class="footer-1__link" href="#">Terms</a>
    <span class="footer-1__sep">&middot;</span>
    <a class="footer-1__link" href="#">Contact</a>
  </nav>
  <p class="footer-1__copy">&copy; 2026 Company Name. All rights reserved.</p>
</footer>
      `}
      css={`
* { margin: 0; padding: 0; box-sizing: border-box; }

body {
  font-family: system-ui, sans-serif;
  background: var(--bg);
  color: var(--fg);
  display: flex;
  flex-direction: column;
  min-height: 200px;
  justify-content: flex-end;
}

.footer-1 {
  text-align: center;
  padding: var(--space-lg) var(--space-md);
  border-top: 1px solid var(--border);
  background: var(--bg-subtle);
}

.footer-1__links {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: var(--space-sm);
  margin-bottom: var(--space-sm);
  flex-wrap: wrap;
}

.footer-1__link {
  font-size: var(--font-sm);
  color: var(--fg-muted);
  text-decoration: none;
  transition: color 0.15s ease;
}

.footer-1__link:hover {
  color: var(--accent);
}

.footer-1__sep {
  color: var(--border);
  font-size: var(--font-sm);
}

.footer-1__copy {
  font-size: var(--font-sm);
  color: var(--fg-muted);
}
      `}
    />

    <HtmlPreview
      client:visible
      title="2. Multi-Column Footer"
      html={`
<footer class="footer-2">
  <div class="footer-2__grid">
    <div class="footer-2__col">
      <h3 class="footer-2__heading">Product</h3>
      <ul class="footer-2__list">
        <li><a class="footer-2__link" href="#">Features</a></li>
        <li><a class="footer-2__link" href="#">Pricing</a></li>
        <li><a class="footer-2__link" href="#">Changelog</a></li>
        <li><a class="footer-2__link" href="#">Roadmap</a></li>
      </ul>
    </div>
    <div class="footer-2__col">
      <h3 class="footer-2__heading">Company</h3>
      <ul class="footer-2__list">
        <li><a class="footer-2__link" href="#">About</a></li>
        <li><a class="footer-2__link" href="#">Blog</a></li>
        <li><a class="footer-2__link" href="#">Careers</a></li>
        <li><a class="footer-2__link" href="#">Press</a></li>
      </ul>
    </div>
    <div class="footer-2__col">
      <h3 class="footer-2__heading">Resources</h3>
      <ul class="footer-2__list">
        <li><a class="footer-2__link" href="#">Documentation</a></li>
        <li><a class="footer-2__link" href="#">Guides</a></li>
        <li><a class="footer-2__link" href="#">API Reference</a></li>
        <li><a class="footer-2__link" href="#">Community</a></li>
      </ul>
    </div>
    <div class="footer-2__col">
      <h3 class="footer-2__heading">Legal</h3>
      <ul class="footer-2__list">
        <li><a class="footer-2__link" href="#">Privacy</a></li>
        <li><a class="footer-2__link" href="#">Terms</a></li>
        <li><a class="footer-2__link" href="#">License</a></li>
        <li><a class="footer-2__link" href="#">Cookies</a></li>
      </ul>
    </div>
  </div>
  <div class="footer-2__bottom">
    <p class="footer-2__copy">&copy; 2026 Company Name. All rights reserved.</p>
  </div>
</footer>
      `}
      css={`
* { margin: 0; padding: 0; box-sizing: border-box; }

body {
  font-family: system-ui, sans-serif;
  background: var(--bg);
  color: var(--fg);
}

.footer-2 {
  background: var(--fg);
  color: var(--bg);
  padding: var(--space-lg) var(--space-md);
}

.footer-2__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--space-lg);
  max-width: 800px;
  margin: 0 auto;
}

.footer-2__heading {
  font-size: var(--font-sm);
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-bottom: var(--space-md);
  color: var(--bg);
}

.footer-2__list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
}

.footer-2__link {
  font-size: var(--font-sm);
  color: var(--border);
  text-decoration: none;
  transition: color 0.15s ease;
}

.footer-2__link:hover {
  color: var(--bg);
}

.footer-2__bottom {
  max-width: 800px;
  margin: 0 auto;
  padding-top: var(--space-lg);
  margin-top: var(--space-lg);
  border-top: 1px solid hsl(220 25% 25%);
}

.footer-2__copy {
  font-size: var(--font-sm);
  color: var(--border);
}
      `}
    />

    <HtmlPreview
      client:visible
      title="3. Footer with Newsletter Form"
      html={`
<footer class="footer-3">
  <div class="footer-3__inner">
    <div class="footer-3__info">
      <h3 class="footer-3__heading">Stay Updated</h3>
      <p class="footer-3__desc">Get the latest news and updates delivered to your inbox.</p>
    </div>
    <form class="footer-3__form">
      <input class="footer-3__input" type="email" placeholder="Enter your email" />
      <button class="footer-3__button" type="submit">Subscribe</button>
    </form>
  </div>
  <div class="footer-3__bottom">
    <p class="footer-3__copy">&copy; 2026 Company Name. All rights reserved.</p>
    <nav class="footer-3__links">
      <a class="footer-3__link" href="#">Privacy</a>
      <a class="footer-3__link" href="#">Terms</a>
      <a class="footer-3__link" href="#">Contact</a>
    </nav>
  </div>
</footer>
      `}
      css={`
* { margin: 0; padding: 0; box-sizing: border-box; }

body {
  font-family: system-ui, sans-serif;
  background: var(--bg);
  color: var(--fg);
}

.footer-3 {
  background: var(--bg-subtle);
  border-top: 1px solid var(--border);
  padding: var(--space-lg) var(--space-md);
}

.footer-3__inner {
  max-width: 600px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-lg);
  margin-bottom: var(--space-lg);
}

.footer-3__heading {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--fg);
  margin-bottom: 4px;
}

.footer-3__desc {
  font-size: var(--font-sm);
  color: var(--fg-muted);
}

.footer-3__form {
  display: flex;
  gap: 0;
  flex-shrink: 0;
  border: 1px solid var(--border);
  border-radius: var(--radius);
  overflow: hidden;
}

.footer-3__form:focus-within {
  border-color: var(--accent);
  box-shadow: 0 0 0 3px hsl(220 70% 50% / 0.15);
}

.footer-3__input {
  font-family: system-ui, sans-serif;
  font-size: var(--font-sm);
  padding: var(--space-sm) var(--space-md);
  border: none;
  background: var(--bg);
  color: var(--fg);
  outline: none;
  width: 200px;
}

.footer-3__input::placeholder {
  color: var(--border);
}

.footer-3__button {
  font-family: system-ui, sans-serif;
  font-size: var(--font-sm);
  font-weight: 600;
  padding: var(--space-sm) var(--space-md);
  border: none;
  background: var(--accent);
  color: var(--bg);
  cursor: pointer;
  white-space: nowrap;
  transition: background 0.15s ease;
}

.footer-3__button:hover {
  background: var(--accent-hover);
}

.footer-3__bottom {
  max-width: 600px;
  margin: 0 auto;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: var(--space-md);
  border-top: 1px solid var(--border);
}

.footer-3__copy {
  font-size: var(--font-sm);
  color: var(--fg-muted);
}

.footer-3__links {
  display: flex;
  gap: var(--space-md);
}

.footer-3__link {
  font-size: var(--font-sm);
  color: var(--fg-muted);
  text-decoration: none;
  transition: color 0.15s ease;
}

.footer-3__link:hover {
  color: var(--accent);
}
      `}
    />

    <HtmlPreview
      client:visible
      title="4. Minimal Footer"
      html={`
<footer class="footer-4">
  <p class="footer-4__copy">&copy; 2026 Company Name</p>
</footer>
      `}
      css={`
* { margin: 0; padding: 0; box-sizing: border-box; }

body {
  font-family: system-ui, sans-serif;
  background: var(--bg);
  display: flex;
  flex-direction: column;
  min-height: 120px;
  justify-content: flex-end;
}

.footer-4 {
  text-align: center;
  padding: var(--space-lg) var(--space-md);
  border-top: 1px solid var(--border);
}

.footer-4__copy {
  font-size: var(--font-sm);
  color: var(--fg-muted);
}
      `}
    />

  </div>
</BaseLayout>
