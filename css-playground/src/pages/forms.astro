  gap: var(--space-xs);
}

.form-2__label {
  font-size: var(--font-sm);
  font-weight: 500;
  color: var(--fg-muted);
}

.form-2__input,
.form-2__textarea {
  font-family: system-ui, sans-serif;
  font-size: var(--font-md);
  padding: var(--space-sm) var(--space-md);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  background: var(--bg);
  color: var(--fg);
