    />

    <HtmlPreview
      client:load
      title="4. Stacked Labels Form"
      html={`
<div class="form-4">
  <h2 class="form-4__title">Create Account</h2>
  <form class="form-4__form">
    <div class="form-4__field">
      <label class="form-4__label" for="stacked-first">First Name</label>
      <input class="form-4__input" type="text" id="stacked-first" />
    </div>
    <div class="form-4__field">
      <label class="form-4__label" for="stacked-last">Last Name</label>
      <input class="form-4__input" type="text" id="stacked-last" />
    </div>
    <div class="form-4__field">
      <label class="form-4__label" for="stacked-email">Email Address</label>
      <input class="form-4__input" type="email" id="stacked-email" />
    </div>
    <div class="form-4__field">
      <label class="form-4__label" for="stacked-pass">Password</label>
      <input class="form-4__input" type="password" id="stacked-pass" />
