    />

    <HtmlPreview
      client:load
      title="5. Floating Labels Form"
      html={`
<div class="form-5">
  <h2 class="form-5__title">Floating Labels</h2>
  <form class="form-5__form">
    <div class="form-5__field">
      <input class="form-5__input" type="text" id="float-name" placeholder=" " />
      <label class="form-5__label" for="float-name">Full Name</label>
    </div>
    <div class="form-5__field">
      <input class="form-5__input" type="email" id="float-email" placeholder=" " />
      <label class="form-5__label" for="float-email">Email Address</label>
    </div>
    <div class="form-5__field">
      <input class="form-5__input" type="password" id="float-pass" placeholder=" " />
      <label class="form-5__label" for="float-pass">Password</label>
    </div>
    <button class="form-5__button" type="submit">Continue</button>
  </form>
</div>
      `}
      css={`
:root {
  --space-xs: 8px;
  --space-sm: 12px;
  --space-md: 20px;
  --space-lg: 32px;
  --radius: 8px;
  --accent: hsl(220 70% 50%);
  --accent-hover: hsl(220 70% 42%);
  --fg: hsl(220 25% 15%);
  --fg-muted: hsl(220 10% 40%);
  --bg: hsl(0 0% 100%);
  --bg-subtle: hsl(220 15% 96%);
  --border: hsl(220 15% 85%);
  --font-sm: 0.85rem;
  --font-md: 1rem;
  --font-lg: 1.1rem;
}

* { margin: 0; padding: 0; box-sizing: border-box; }

body {
  font-family: system-ui, sans-serif;
  background: var(--bg);
  color: var(--fg);
  padding: var(--space-lg);
}

.form-5 {
  max-width: 400px;
  margin: 0 auto;
}

.form-5__title {
  font-size: var(--font-lg);
  font-weight: 600;
  margin-bottom: var(--space-md);
  color: var(--fg);
}

.form-5__form {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.form-5__field {
  position: relative;
}

.form-5__input {
  font-family: system-ui, sans-serif;
  font-size: var(--font-md);
  width: 100%;
  padding: var(--space-md) var(--space-md) var(--space-xs);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  background: var(--bg);
  color: var(--fg);
  outline: none;
  transition: border-color 0.15s ease;
}

.form-5__input:focus {
  border-color: var(--accent);
  box-shadow: 0 0 0 3px hsl(220 70% 50% / 0.15);
}

.form-5__label {
  position: absolute;
  left: var(--space-md);
  top: 50%;
  transform: translateY(-50%);
  font-size: var(--font-md);
  color: var(--fg-muted);
  pointer-events: none;
  transition: all 0.2s ease;
  background: var(--bg);
  padding: 0 4px;
}

.form-5__input:focus + .form-5__label,
.form-5__input:not(:placeholder-shown) + .form-5__label {
  top: 0;
  transform: translateY(-50%);
  font-size: var(--font-sm);
  color: var(--accent);
}

.form-5__button {
  font-family: system-ui, sans-serif;
  font-size: var(--font-md);
  font-weight: 600;
  padding: var(--space-sm) var(--space-md);
  border: none;
  border-radius: var(--radius);
  background: var(--accent);
  color: var(--bg);
  cursor: pointer;
  margin-top: var(--space-xs);
  transition: background 0.15s ease;
}

.form-5__button:hover {
  background: var(--accent-hover);
}

.form-5__button:focus-visible {
  outline: 2px solid var(--accent);
  outline-offset: 2px;
}
      `}
