        <input class="form-6__checkbox" type="checkbox" checked />
        <span class="form-6__track"></span>
      </label>
    </div>
    <div class="form-6__row">
      <div class="form-6__info">
        <span class="form-6__name">Dark Mode</span>
        <span class="form-6__desc">Use dark theme</span>
      </div>
      <label class="form-6__toggle">
        <input class="form-6__checkbox" type="checkbox" />
        <span class="form-6__track"></span>
      </label>
    </div>
    <div class="form-6__row">
      <div class="form-6__info">
        <span class="form-6__name">Auto-save</span>
        <span class="form-6__desc">Save changes automatically</span>
      </div>
      <label class="form-6__toggle">
        <input class="form-6__checkbox" type="checkbox" checked />
        <span class="form-6__track"></span>
      </label>
    </div>
    <div class="form-6__row">
      <div class="form-6__info">
        <span class="form-6__name">Two-Factor Auth</span>
        <span class="form-6__desc">Extra security for your account</span>
      </div>
      <label class="form-6__toggle">
        <input class="form-6__checkbox" type="checkbox" />
        <span class="form-6__track"></span>
      </label>
    </div>
  </form>
</div>
      `}
      css={`
:root {
  --space-xs: 8px;
  --space-sm: 12px;
  --space-md: 20px;
  --space-lg: 32px;
  --radius: 8px;
  --accent: hsl(220 70% 50%);
  --accent-hover: hsl(220 70% 42%);
  --fg: hsl(220 25% 15%);
  --fg-muted: hsl(220 10% 40%);
  --bg: hsl(0 0% 100%);
  --bg-subtle: hsl(220 15% 96%);
  --border: hsl(220 15% 85%);
  --success: hsl(142 71% 45%);
  --font-sm: 0.85rem;
  --font-md: 1rem;
  --font-lg: 1.1rem;
}

* { margin: 0; padding: 0; box-sizing: border-box; }

body {
  font-family: system-ui, sans-serif;
  background: var(--bg);
  color: var(--fg);
  padding: var(--space-lg);
}

.form-6 {
  max-width: 420px;
  margin: 0 auto;
}

.form-6__title {
  font-size: var(--font-lg);
  font-weight: 600;
  margin-bottom: var(--space-md);
  color: var(--fg);
}

.form-6__form {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.form-6__row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-md) 0;
  border-bottom: 1px solid var(--border);
}

.form-6__row:last-child {
  border-bottom: none;
}

.form-6__info {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.form-6__name {
  font-size: var(--font-md);
  font-weight: 500;
  color: var(--fg);
}

.form-6__desc {
  font-size: var(--font-sm);
  color: var(--fg-muted);
}

.form-6__toggle {
  position: relative;
  cursor: pointer;
  flex-shrink: 0;
}

.form-6__checkbox {
  position: absolute;
  opacity: 0;
  width: 0;
  height: 0;
}

.form-6__track {
  display: block;
  width: 44px;
  height: 24px;
  background: var(--border);
  border-radius: 12px;
  position: relative;
  transition: background 0.2s ease;
}

.form-6__track::after {
  content: "";
  position: absolute;
  top: 2px;
  left: 2px;
  width: 20px;
  height: 20px;
  background: var(--bg);
  border-radius: 50%;
  transition: transform 0.2s ease;
  box-shadow: 0 1px 3px hsl(220 25% 15% / 0.2);
}

.form-6__checkbox:checked + .form-6__track {
  background: var(--accent);
}

.form-6__checkbox:checked + .form-6__track::after {
  transform: translateX(20px);
}

.form-6__checkbox:focus-visible + .form-6__track {
  outline: 2px solid var(--accent);
  outline-offset: 2px;
}
      `}
    />

  </div>
</BaseLayout>
