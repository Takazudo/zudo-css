---
import BaseLayout from '../layouts/base-layout.astro';
import HtmlPreview from '../components/html-preview.tsx';
---

<BaseLayout title="Forms" activeCategory="forms">
  <h1 class="text-heading font-bold mb-vsp-lg">Form Patterns</h1>
  <p class="text-body text-muted mb-vsp-xl">6 form/input variations built with strict design tokens.</p>

  <div class="space-y-vsp-xl">

    <HtmlPreview
      client:load
      title="1. Simple Login Form"
      html={`
<div class="form-1">
  <h2 class="form-1__title">Sign In</h2>
  <form class="form-1__form">
    <div class="form-1__field">
      <label class="form-1__label" for="login-email">Email</label>
      <input class="form-1__input" type="email" id="login-email" placeholder="you@example.com" />
    </div>
    <div class="form-1__field">
      <label class="form-1__label" for="login-password">Password</label>
      <input class="form-1__input" type="password" id="login-password" placeholder="••••••••" />
    </div>
    <button class="form-1__button" type="submit">Sign In</button>
  </form>
</div>
      `}
      css={`
:root {
  --space-xs: 8px;
  --space-sm: 12px;
  --space-md: 20px;
  --space-lg: 32px;
  --radius: 8px;
  --accent: hsl(220 70% 50%);
  --accent-hover: hsl(220 70% 42%);
  --fg: hsl(220 25% 15%);
  --fg-muted: hsl(220 10% 40%);
  --bg: hsl(0 0% 100%);
  --bg-subtle: hsl(220 15% 96%);
  --border: hsl(220 15% 85%);
  --font-sm: 0.85rem;
  --font-md: 1rem;
  --font-lg: 1.1rem;
}

* { margin: 0; padding: 0; box-sizing: border-box; }

body {
  font-family: system-ui, sans-serif;
  background: var(--bg);
  color: var(--fg);
  padding: var(--space-lg);
}

.form-1 {
  max-width: 360px;
  margin: 0 auto;
}

.form-1__title {
  font-size: var(--font-lg);
  font-weight: 600;
  margin-bottom: var(--space-md);
  color: var(--fg);
}

.form-1__form {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.form-1__field {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
}

.form-1__label {
  font-size: var(--font-sm);
  font-weight: 500;
  color: var(--fg-muted);
}

.form-1__input {
  font-family: system-ui, sans-serif;
  font-size: var(--font-md);
  padding: var(--space-sm) var(--space-md);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  background: var(--bg);
  color: var(--fg);
  outline: none;
  transition: border-color 0.15s ease;
}

.form-1__input:focus {
  border-color: var(--accent);
  box-shadow: 0 0 0 3px hsl(220 70% 50% / 0.15);
}

.form-1__input::placeholder {
  color: var(--border);
}

.form-1__button {
  font-family: system-ui, sans-serif;
  font-size: var(--font-md);
  font-weight: 600;
  padding: var(--space-sm) var(--space-md);
  border: none;
  border-radius: var(--radius);
  background: var(--accent);
  color: var(--bg);
  cursor: pointer;
  transition: background 0.15s ease;
}

.form-1__button:hover {
  background: var(--accent-hover);
}

.form-1__button:focus-visible {
  outline: 2px solid var(--accent);
  outline-offset: 2px;
}
      `}
    />

    <HtmlPreview
      client:load
      title="2. Contact Form"
      html={`
<div class="form-2">
  <h2 class="form-2__title">Contact Us</h2>
  <form class="form-2__form">
    <div class="form-2__field">
      <label class="form-2__label" for="contact-name">Name</label>
      <input class="form-2__input" type="text" id="contact-name" placeholder="Your name" />
    </div>
    <div class="form-2__field">
      <label class="form-2__label" for="contact-email">Email</label>
      <input class="form-2__input" type="email" id="contact-email" placeholder="you@example.com" />
    </div>
    <div class="form-2__field">
      <label class="form-2__label" for="contact-message">Message</label>
      <textarea class="form-2__textarea" id="contact-message" rows="4" placeholder="How can we help?"></textarea>
    </div>
    <button class="form-2__button" type="submit">Send Message</button>
  </form>
</div>
      `}
      css={`
:root {
  --space-xs: 8px;
