  --font-sm: 0.85rem;
  --font-md: 1rem;
  --font-lg: 1.1rem;
}

* { margin: 0; padding: 0; box-sizing: border-box; }

body {
  font-family: system-ui, sans-serif;
  background: var(--bg);
  color: var(--fg);
  padding: var(--space-lg);
}

.form-2 {
  max-width: 480px;
  margin: 0 auto;
}

.form-2__title {
  font-size: var(--font-lg);
  font-weight: 600;
  margin-bottom: var(--space-md);
  color: var(--fg);
}

.form-2__form {
  display: flex;
