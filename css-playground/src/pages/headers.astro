---
import BaseLayout from '../layouts/base-layout.astro';
import HtmlPreview from '../components/html-preview.tsx';
---

<BaseLayout title="Headers" activeCategory="headers">
  <h1 class="text-heading font-bold mb-vsp-lg">Header Patterns</h1>
  <p class="text-body text-muted mb-vsp-xl">8 header/navigation variations built with strict design tokens.</p>

  <div class="space-y-vsp-xl">
    <section>
      <h2 class="text-subheading font-semibold mb-vsp-sm">1. Simple Horizontal Nav</h2>
      <HtmlPreview
        client:visible
        title="Simple Horizontal Nav"
        html={`<header class="header-1">
  <a href="#" class="header-1__logo">Brand</a>
  <nav class="header-1__nav">
    <a href="#" class="header-1__link header-1__link--active">Home</a>
    <a href="#" class="header-1__link">About</a>
    <a href="#" class="header-1__link">Services</a>
    <a href="#" class="header-1__link">Contact</a>
  </nav>
</header>`}
        css={`* { margin: 0; padding: 0; box-sizing: border-box; }

.header-1 {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-sm) var(--space-md);
  background: var(--bg);
  border-bottom: 1px solid var(--border);
  font-family: system-ui, sans-serif;
}

.header-1__logo {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--fg);
  text-decoration: none;
}

.header-1__nav {
  display: flex;
  gap: var(--space-md);
}

.header-1__link {
  font-size: var(--font-md);
  color: var(--fg-muted);
  text-decoration: none;
  transition: color 0.2s;
}

.header-1__link:hover {
  color: var(--accent);
}

.header-1__link--active {
  color: var(--accent);
  font-weight: 600;
}`}
        height={60}
      />
    </section>

    <section>
      <h2 class="text-subheading font-semibold mb-vsp-sm">2. Nav with CTA Button</h2>
      <HtmlPreview
        client:visible
        title="Nav with CTA Button"
        html={`<header class="header-2">
  <a href="#" class="header-2__logo">Brand</a>
  <nav class="header-2__nav">
    <a href="#" class="header-2__link">Features</a>
    <a href="#" class="header-2__link">Pricing</a>
    <a href="#" class="header-2__link">Docs</a>
  </nav>
  <a href="#" class="header-2__cta">Get Started</a>
</header>`}
        css={`* { margin: 0; padding: 0; box-sizing: border-box; }

.header-2 {
  display: flex;
  align-items: center;
  padding: var(--space-sm) var(--space-md);
  background: var(--bg);
  border-bottom: 1px solid var(--border);
  font-family: system-ui, sans-serif;
}

.header-2__logo {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--fg);
  text-decoration: none;
  margin-right: auto;
}

.header-2__nav {
  display: flex;
  gap: var(--space-md);
  margin-right: var(--space-md);
}

.header-2__link {
  font-size: var(--font-md);
  color: var(--fg-muted);
  text-decoration: none;
  transition: color 0.2s;
}

.header-2__link:hover {
  color: var(--accent);
}

.header-2__cta {
  font-size: var(--font-sm);
  font-weight: 600;
  color: var(--bg);
  background: var(--accent);
  padding: var(--space-xs) var(--space-md);
  border-radius: var(--radius);
  text-decoration: none;
  transition: background 0.2s;
}

.header-2__cta:hover {
  background: var(--accent-hover);
}`}
        height={60}
      />
    </section>

    <section>
      <h2 class="text-subheading font-semibold mb-vsp-sm">3. Stacked Nav</h2>
      <HtmlPreview
        client:visible
        title="Stacked Nav"
        html={`<header class="header-3">
  <div class="header-3__top">
    <a href="#" class="header-3__logo">Brand</a>
  </div>
  <nav class="header-3__nav">
    <a href="#" class="header-3__link header-3__link--active">Home</a>
    <a href="#" class="header-3__link">Products</a>
    <a href="#" class="header-3__link">About</a>
    <a href="#" class="header-3__link">Blog</a>
    <a href="#" class="header-3__link">Contact</a>
  </nav>
</header>`}
        css={`* { margin: 0; padding: 0; box-sizing: border-box; }

.header-3 {
  background: var(--bg);
  border-bottom: 1px solid var(--border);
  font-family: system-ui, sans-serif;
}

.header-3__top {
  padding: var(--space-sm) var(--space-md);
  text-align: center;
}

.header-3__logo {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--fg);
  text-decoration: none;
}

.header-3__nav {
  display: flex;
  justify-content: center;
  gap: var(--space-md);
  padding: var(--space-xs) var(--space-md);
  background: var(--bg-subtle);
}

.header-3__link {
  font-size: var(--font-sm);
  color: var(--fg-muted);
  text-decoration: none;
  padding: var(--space-xs) var(--space-sm);
  border-bottom: 2px solid transparent;
  transition: color 0.2s, border-color 0.2s;
}

.header-3__link:hover {
  color: var(--accent);
}

.header-3__link--active {
  color: var(--accent);
  border-bottom-color: var(--accent);
  font-weight: 600;
}`}
        height={90}
      />
    </section>

    <section>
      <h2 class="text-subheading font-semibold mb-vsp-sm">4. Centered Nav</h2>
      <HtmlPreview
        client:visible
        title="Centered Nav"
        html={`<header class="header-4">
  <a href="#" class="header-4__logo">Brand</a>
  <nav class="header-4__nav">
    <a href="#" class="header-4__link header-4__link--active">Home</a>
    <a href="#" class="header-4__link">About</a>
    <a href="#" class="header-4__link">Work</a>
    <a href="#" class="header-4__link">Contact</a>
  </nav>
</header>`}
        css={`* { margin: 0; padding: 0; box-sizing: border-box; }

.header-4 {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-xs);
  padding: var(--space-md) var(--space-md) var(--space-sm);
  background: var(--bg);
  border-bottom: 1px solid var(--border);
  font-family: system-ui, sans-serif;
}

.header-4__logo {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--fg);
  text-decoration: none;
}

.header-4__nav {
  display: flex;
  gap: var(--space-lg);
}

.header-4__link {
  font-size: var(--font-sm);
  color: var(--fg-muted);
  text-decoration: none;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  transition: color 0.2s;
}

.header-4__link:hover {
  color: var(--accent);
}

.header-4__link--active {
  color: var(--accent);
  font-weight: 600;
}`}
        height={80}
      />
    </section>

    <section>
      <h2 class="text-subheading font-semibold mb-vsp-sm">5. Split Nav</h2>
      <HtmlPreview
        client:visible
        title="Split Nav"
        html={`<header class="header-5">
  <a href="#" class="header-5__logo">Brand</a>
  <nav class="header-5__nav">
    <a href="#" class="header-5__link header-5__link--active">Home</a>
    <a href="#" class="header-5__link">Products</a>
    <a href="#" class="header-5__link">About</a>
  </nav>
  <div class="header-5__actions">
    <a href="#" class="header-5__action">Log In</a>
    <a href="#" class="header-5__action header-5__action--primary">Sign Up</a>
  </div>
</header>`}
        css={`* { margin: 0; padding: 0; box-sizing: border-box; }

.header-5 {
  display: flex;
  align-items: center;
  padding: var(--space-sm) var(--space-md);
  background: var(--bg);
  border-bottom: 1px solid var(--border);
  font-family: system-ui, sans-serif;
}

.header-5__logo {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--fg);
  text-decoration: none;
}

.header-5__nav {
  display: flex;
  gap: var(--space-md);
  margin: 0 auto;
}

.header-5__link {
  font-size: var(--font-md);
  color: var(--fg-muted);
  text-decoration: none;
  transition: color 0.2s;
}

.header-5__link:hover {
  color: var(--accent);
}

.header-5__link--active {
  color: var(--accent);
  font-weight: 600;
}

.header-5__actions {
  display: flex;
  gap: var(--space-sm);
  align-items: center;
}

.header-5__action {
  font-size: var(--font-sm);
  color: var(--fg-muted);
  text-decoration: none;
  padding: var(--space-xs) var(--space-sm);
  transition: color 0.2s;
}

.header-5__action:hover {
  color: var(--accent);
}

.header-5__action--primary {
  color: var(--bg);
  background: var(--accent);
  border-radius: var(--radius);
  font-weight: 600;
}

.header-5__action--primary:hover {
  color: var(--bg);
  background: var(--accent-hover);
}`}
        height={60}
      />
    </section>

    <section>
      <h2 class="text-subheading font-semibold mb-vsp-sm">6. Pill Nav</h2>
      <HtmlPreview
        client:visible
        title="Pill Nav"
        html={`<header class="header-6">
  <a href="#" class="header-6__logo">Brand</a>
  <nav class="header-6__nav">
    <a href="#" class="header-6__pill header-6__pill--active">Dashboard</a>
    <a href="#" class="header-6__pill">Analytics</a>
    <a href="#" class="header-6__pill">Settings</a>
    <a href="#" class="header-6__pill">Help</a>
  </nav>
</header>`}
        css={`* { margin: 0; padding: 0; box-sizing: border-box; }

.header-6 {
  display: flex;
  align-items: center;
  gap: var(--space-md);
  padding: var(--space-sm) var(--space-md);
  background: var(--bg);
  border-bottom: 1px solid var(--border);
  font-family: system-ui, sans-serif;
}

.header-6__logo {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--fg);
  text-decoration: none;
  margin-right: auto;
}

.header-6__nav {
  display: flex;
  gap: var(--space-xs);
}

.header-6__pill {
  font-size: var(--font-sm);
  color: var(--fg-muted);
  text-decoration: none;
  padding: var(--space-xs) var(--space-sm);
  border-radius: 999px;
  background: var(--bg-subtle);
  transition: background 0.2s, color 0.2s;
}

.header-6__pill:hover {
  background: var(--border);
  color: var(--fg);
}

.header-6__pill--active {
  background: var(--accent);
  color: var(--bg);
  font-weight: 600;
}

.header-6__pill--active:hover {
  background: var(--accent-hover);
  color: var(--bg);
}`}
        height={60}
      />
    </section>

    <section>
      <h2 class="text-subheading font-semibold mb-vsp-sm">7. Tab-Style Nav</h2>
      <HtmlPreview
        client:visible
        title="Tab-Style Nav"
        html={`<header class="header-7">
  <a href="#" class="header-7__logo">Brand</a>
  <nav class="header-7__nav">
    <a href="#" class="header-7__tab header-7__tab--active">Overview</a>
    <a href="#" class="header-7__tab">Features</a>
    <a href="#" class="header-7__tab">Integrations</a>
    <a href="#" class="header-7__tab">Pricing</a>
  </nav>
</header>`}
        css={`* { margin: 0; padding: 0; box-sizing: border-box; }

.header-7 {
  display: flex;
  align-items: stretch;
  background: var(--bg);
  border-bottom: 1px solid var(--border);
  font-family: system-ui, sans-serif;
}

.header-7__logo {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--fg);
  text-decoration: none;
  display: flex;
  align-items: center;
  padding: var(--space-sm) var(--space-md);
  margin-right: var(--space-lg);
}

.header-7__nav {
  display: flex;
}

.header-7__tab {
  font-size: var(--font-md);
  color: var(--fg-muted);
  text-decoration: none;
  padding: var(--space-sm) var(--space-md);
  border-bottom: 2px solid transparent;
  display: flex;
  align-items: center;
  transition: color 0.2s, border-color 0.2s;
}

.header-7__tab:hover {
  color: var(--fg);
  border-bottom-color: var(--border);
}

.header-7__tab--active {
  color: var(--accent);
  border-bottom-color: var(--accent);
  font-weight: 600;
}`}
        height={60}
      />
    </section>

    <section>
      <h2 class="text-subheading font-semibold mb-vsp-sm">8. Minimal Nav</h2>
      <HtmlPreview
        client:visible
        title="Minimal Nav"
        html={`<header class="header-8">
  <a href="#" class="header-8__logo">Brand</a>
  <button class="header-8__menu" aria-label="Menu">
    <span class="header-8__menu-icon"></span>
  </button>
</header>`}
        css={`* { margin: 0; padding: 0; box-sizing: border-box; }

.header-8 {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-sm) var(--space-md);
  background: var(--bg);
  border-bottom: 1px solid var(--border);
  font-family: system-ui, sans-serif;
}

.header-8__logo {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--fg);
  text-decoration: none;
}

.header-8__menu {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  width: var(--space-lg);
  height: var(--space-lg);
  background: none;
  border: 1px solid var(--border);
  border-radius: var(--radius);
  cursor: pointer;
  transition: border-color 0.2s;
}

.header-8__menu:hover {
  border-color: var(--accent);
}

.header-8__menu-icon,
.header-8__menu-icon::before,
.header-8__menu-icon::after {
  display: block;
  width: var(--space-md);
  height: 1px;
  background: var(--fg);
  border-radius: 1px;
}

.header-8__menu-icon {
  position: relative;
}

.header-8__menu-icon::before,
.header-8__menu-icon::after {
  content: "";
  position: absolute;
  left: 0;
}

.header-8__menu-icon::before {
  top: calc(-1 * var(--space-xs));
}

.header-8__menu-icon::after {
  top: var(--space-xs);
}`}
        height={60}
      />
    </section>
  </div>
</BaseLayout>
