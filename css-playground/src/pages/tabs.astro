---
import BaseLayout from '../layouts/base-layout.astro';
import HtmlPreview from '../components/html-preview.tsx';
---

<BaseLayout title="Tabs" activeCategory="tabs">
  <h1 class="text-heading font-bold mb-vsp-lg">Tab Patterns</h1>
  <p class="text-body text-muted mb-vsp-xl">6 tab variations built with strict design tokens.</p>

  <div class="space-y-vsp-xl">

    <HtmlPreview
      client:visible
      title="1. Underline Tabs"
      html={`
<div class="tab-1">
  <input class="tab-1__radio" type="radio" name="tab-1" id="tab-1-a" checked />
  <input class="tab-1__radio" type="radio" name="tab-1" id="tab-1-b" />
  <input class="tab-1__radio" type="radio" name="tab-1" id="tab-1-c" />
  <nav class="tab-1__nav">
    <label class="tab-1__item" for="tab-1-a">Overview</label>
    <label class="tab-1__item" for="tab-1-b">Features</label>
    <label class="tab-1__item" for="tab-1-c">Pricing</label>
  </nav>
  <div class="tab-1__panels">
    <div class="tab-1__panel tab-1__panel--a">Overview content goes here. This panel shows a brief summary of the product.</div>
    <div class="tab-1__panel tab-1__panel--b">Features content goes here. Explore all the capabilities available.</div>
    <div class="tab-1__panel tab-1__panel--c">Pricing content goes here. Choose the plan that fits your needs.</div>
  </div>
</div>
      `}
      css={`
* { margin: 0; padding: 0; box-sizing: border-box; }

body {
  font-family: system-ui, sans-serif;
  background: var(--bg);
  color: var(--fg);
  padding: var(--space-lg);
}

.tab-1 {
  max-width: 500px;
  margin: 0 auto;
}

.tab-1__nav {
  display: flex;
  border-bottom: 1px solid var(--border);
}

.tab-1__radio {
  position: absolute;
  opacity: 0;
  width: 0;
  height: 0;
}

.tab-1__item {
  font-size: var(--font-md);
  padding: var(--space-sm) var(--space-md);
  color: var(--fg-muted);
  cursor: pointer;
  border-bottom: 2px solid transparent;
  margin-bottom: -1px;
  transition: color 0.15s ease, border-color 0.15s ease;
}

.tab-1__item:hover {
  color: var(--fg);
}

#tab-1-a:checked ~ .tab-1__nav .tab-1__item[for="tab-1-a"],
#tab-1-b:checked ~ .tab-1__nav .tab-1__item[for="tab-1-b"],
#tab-1-c:checked ~ .tab-1__nav .tab-1__item[for="tab-1-c"] {
  color: var(--accent);
  border-bottom-color: var(--accent);
  font-weight: 600;
}

.tab-1__panels {
  padding: var(--space-md) 0;
}

.tab-1__panel {
  display: none;
  font-size: var(--font-md);
  color: var(--fg-muted);
  line-height: 1.6;
}

#tab-1-a:checked ~ .tab-1__panels .tab-1__panel--a,
#tab-1-b:checked ~ .tab-1__panels .tab-1__panel--b,
#tab-1-c:checked ~ .tab-1__panels .tab-1__panel--c {
  display: block;
}
      `}
    />

    <HtmlPreview
      client:visible
      title="2. Pill Tabs"
      html={`
<div class="tab-2">
  <input class="tab-2__radio" type="radio" name="tab-2" id="tab-2-a" checked />
  <input class="tab-2__radio" type="radio" name="tab-2" id="tab-2-b" />
  <input class="tab-2__radio" type="radio" name="tab-2" id="tab-2-c" />
  <input class="tab-2__radio" type="radio" name="tab-2" id="tab-2-d" />
  <nav class="tab-2__nav">
    <label class="tab-2__item" for="tab-2-a">All</label>
    <label class="tab-2__item" for="tab-2-b">Active</label>
    <label class="tab-2__item" for="tab-2-c">Archived</label>
    <label class="tab-2__item" for="tab-2-d">Drafts</label>
  </nav>
  <div class="tab-2__panels">
    <div class="tab-2__panel tab-2__panel--a">Showing all items in this view.</div>
    <div class="tab-2__panel tab-2__panel--b">Showing only active items.</div>
    <div class="tab-2__panel tab-2__panel--c">Showing archived items.</div>
    <div class="tab-2__panel tab-2__panel--d">Showing draft items.</div>
  </div>
</div>
      `}
      css={`
* { margin: 0; padding: 0; box-sizing: border-box; }

body {
  font-family: system-ui, sans-serif;
  background: var(--bg);
  color: var(--fg);
  padding: var(--space-lg);
}

.tab-2 {
  max-width: 500px;
  margin: 0 auto;
}

.tab-2__nav {
  display: flex;
  gap: var(--space-xs);
  background: var(--bg-subtle);
  padding: 4px;
  border-radius: var(--radius);
}

.tab-2__radio {
  position: absolute;
  opacity: 0;
  width: 0;
  height: 0;
}

.tab-2__item {
  font-size: var(--font-sm);
  padding: var(--space-xs) var(--space-md);
  color: var(--fg-muted);
  cursor: pointer;
  border-radius: calc(var(--radius) - 2px);
  transition: background 0.15s ease, color 0.15s ease;
  text-align: center;
  flex: 1;
}

.tab-2__item:hover {
  color: var(--fg);
}

#tab-2-a:checked ~ .tab-2__nav .tab-2__item[for="tab-2-a"],
#tab-2-b:checked ~ .tab-2__nav .tab-2__item[for="tab-2-b"],
#tab-2-c:checked ~ .tab-2__nav .tab-2__item[for="tab-2-c"],
#tab-2-d:checked ~ .tab-2__nav .tab-2__item[for="tab-2-d"] {
  background: var(--bg);
  color: var(--fg);
  font-weight: 600;
  box-shadow: 0 1px 3px hsl(220 25% 15% / 0.1);
}

.tab-2__panels {
  padding: var(--space-md) 0;
}

.tab-2__panel {
  display: none;
  font-size: var(--font-md);
  color: var(--fg-muted);
  line-height: 1.6;
}

#tab-2-a:checked ~ .tab-2__panels .tab-2__panel--a,
#tab-2-b:checked ~ .tab-2__panels .tab-2__panel--b,
#tab-2-c:checked ~ .tab-2__panels .tab-2__panel--c,
#tab-2-d:checked ~ .tab-2__panels .tab-2__panel--d {
  display: block;
}
      `}
    />

    <HtmlPreview
      client:visible
      title="3. Boxed Tabs"
      html={`
<div class="tab-3">
  <input class="tab-3__radio" type="radio" name="tab-3" id="tab-3-a" checked />
  <input class="tab-3__radio" type="radio" name="tab-3" id="tab-3-b" />
  <input class="tab-3__radio" type="radio" name="tab-3" id="tab-3-c" />
  <nav class="tab-3__nav">
    <label class="tab-3__item" for="tab-3-a">Details</label>
    <label class="tab-3__item" for="tab-3-b">Reviews</label>
    <label class="tab-3__item" for="tab-3-c">Specs</label>
  </nav>
  <div class="tab-3__panels">
    <div class="tab-3__panel tab-3__panel--a">Product details and description appear here.</div>
    <div class="tab-3__panel tab-3__panel--b">Customer reviews and ratings are shown here.</div>
    <div class="tab-3__panel tab-3__panel--c">Technical specifications and dimensions listed here.</div>
  </div>
</div>
      `}
      css={`
* { margin: 0; padding: 0; box-sizing: border-box; }

body {
  font-family: system-ui, sans-serif;
  background: var(--bg);
  color: var(--fg);
  padding: var(--space-lg);
}

.tab-3 {
  max-width: 500px;
  margin: 0 auto;
}

.tab-3__nav {
  display: flex;
}

.tab-3__radio {
  position: absolute;
  opacity: 0;
  width: 0;
  height: 0;
}

.tab-3__item {
  font-size: var(--font-md);
  padding: var(--space-sm) var(--space-md);
  color: var(--fg-muted);
  cursor: pointer;
  border: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
  background: var(--bg-subtle);
  margin-right: -1px;
  transition: background 0.15s ease, color 0.15s ease;
}

.tab-3__item:first-of-type {
  border-radius: var(--radius) 0 0 0;
}

.tab-3__item:last-of-type {
  border-radius: 0 var(--radius) 0 0;
  margin-right: 0;
}

.tab-3__item:hover {
  background: var(--bg);
}

#tab-3-a:checked ~ .tab-3__nav .tab-3__item[for="tab-3-a"],
#tab-3-b:checked ~ .tab-3__nav .tab-3__item[for="tab-3-b"],
#tab-3-c:checked ~ .tab-3__nav .tab-3__item[for="tab-3-c"] {
  background: var(--bg);
  color: var(--fg);
  font-weight: 600;
  border-bottom-color: var(--bg);
  position: relative;
  z-index: 1;
}

.tab-3__panels {
  border: 1px solid var(--border);
  border-top: none;
  border-radius: 0 0 var(--radius) var(--radius);
  padding: var(--space-md);
  margin-top: -1px;
}

.tab-3__panel {
  display: none;
  font-size: var(--font-md);
  color: var(--fg-muted);
  line-height: 1.6;
}

#tab-3-a:checked ~ .tab-3__panels .tab-3__panel--a,
#tab-3-b:checked ~ .tab-3__panels .tab-3__panel--b,
#tab-3-c:checked ~ .tab-3__panels .tab-3__panel--c {
  display: block;
}
      `}
    />

    <HtmlPreview
      client:visible
      title="4. Vertical Tabs"
      html={`
<div class="tab-4">
  <input class="tab-4__radio" type="radio" name="tab-4" id="tab-4-a" checked />
  <input class="tab-4__radio" type="radio" name="tab-4" id="tab-4-b" />
  <input class="tab-4__radio" type="radio" name="tab-4" id="tab-4-c" />
  <nav class="tab-4__nav">
    <label class="tab-4__item" for="tab-4-a">Account</label>
    <label class="tab-4__item" for="tab-4-b">Security</label>
    <label class="tab-4__item" for="tab-4-c">Billing</label>
  </nav>
  <div class="tab-4__panels">
    <div class="tab-4__panel tab-4__panel--a">Manage your account settings, profile information, and preferences here.</div>
    <div class="tab-4__panel tab-4__panel--b">Configure security options including passwords, two-factor auth, and sessions.</div>
    <div class="tab-4__panel tab-4__panel--c">View and update your billing information, invoices, and payment methods.</div>
  </div>
</div>
      `}
      css={`
* { margin: 0; padding: 0; box-sizing: border-box; }

body {
  font-family: system-ui, sans-serif;
  background: var(--bg);
  color: var(--fg);
  padding: var(--space-lg);
}

.tab-4 {
  max-width: 600px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 160px 1fr;
  gap: 0;
  border: 1px solid var(--border);
  border-radius: var(--radius);
  overflow: hidden;
}

.tab-4__radio {
  position: absolute;
  opacity: 0;
  width: 0;
  height: 0;
}

.tab-4__nav {
  display: flex;
  flex-direction: column;
  background: var(--bg-subtle);
  border-right: 1px solid var(--border);
}

.tab-4__item {
  font-size: var(--font-md);
  padding: var(--space-sm) var(--space-md);
  color: var(--fg-muted);
  cursor: pointer;
  border-left: 3px solid transparent;
  transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
}

.tab-4__item:hover {
  background: var(--bg);
  color: var(--fg);
}

#tab-4-a:checked ~ .tab-4__nav .tab-4__item[for="tab-4-a"],
#tab-4-b:checked ~ .tab-4__nav .tab-4__item[for="tab-4-b"],
#tab-4-c:checked ~ .tab-4__nav .tab-4__item[for="tab-4-c"] {
  background: var(--bg);
  color: var(--accent);
  font-weight: 600;
  border-left-color: var(--accent);
}

.tab-4__panels {
  padding: var(--space-md);
}

.tab-4__panel {
  display: none;
  font-size: var(--font-md);
  color: var(--fg-muted);
  line-height: 1.6;
}

#tab-4-a:checked ~ .tab-4__panels .tab-4__panel--a,
#tab-4-b:checked ~ .tab-4__panels .tab-4__panel--b,
#tab-4-c:checked ~ .tab-4__panels .tab-4__panel--c {
  display: block;
}
      `}
    />

