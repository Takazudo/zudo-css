---
import BaseLayout from '../layouts/base-layout.astro';
import HtmlPreview from '../components/html-preview.tsx';
---

<BaseLayout title="Toasts" activeCategory="toasts">
  <h1 class="text-heading font-bold mb-vsp-lg">Toast Patterns</h1>
  <p class="text-body text-muted mb-vsp-xl">4 toast/notification variations built with strict design tokens.</p>

  <div class="space-y-vsp-xl">

    <HtmlPreview
      client:visible
      title="1. Success Toast"
      html={`
<div class="toast-1">
  <div class="toast-1__toast">
    <span class="toast-1__icon">&#10003;</span>
    <div class="toast-1__content">
      <span class="toast-1__title">Success</span>
      <span class="toast-1__message">Your changes have been saved successfully.</span>
    </div>
  </div>
</div>
      `}
      css={`
.toast-1 {
  max-width: 400px;
  margin: 0 auto;
}

.toast-1__toast {
  display: flex;
  align-items: flex-start;
  gap: var(--space-sm);
  padding: var(--space-md);
  background: var(--bg);
  border: 1px solid var(--border);
  border-left: 4px solid var(--success);
  border-radius: var(--radius);
  box-shadow: 0 4px 12px hsl(220 25% 15% / 0.08);
}

.toast-1__icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 24px;
  height: 24px;
  background: var(--success);
  color: var(--bg);
  border-radius: 50%;
  font-size: var(--font-sm);
  font-weight: 700;
  flex-shrink: 0;
  line-height: 1;
}

.toast-1__content {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.toast-1__title {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--fg);
}

.toast-1__message {
  font-size: var(--font-sm);
  color: var(--fg-muted);
  line-height: 1.4;
}
      `}
    />

    <HtmlPreview
      client:visible
      title="2. Error Toast"
      html={`
<div class="toast-2">
  <div class="toast-2__toast">
    <span class="toast-2__icon">&times;</span>
    <div class="toast-2__content">
      <span class="toast-2__title">Error</span>
      <span class="toast-2__message">Something went wrong. Please try again later.</span>
    </div>
  </div>
</div>
      `}
      css={`
.toast-2 {
  max-width: 400px;
  margin: 0 auto;
}

.toast-2__toast {
  display: flex;
  align-items: flex-start;
  gap: var(--space-sm);
  padding: var(--space-md);
  background: var(--bg);
  border: 1px solid var(--border);
  border-left: 4px solid var(--danger);
  border-radius: var(--radius);
  box-shadow: 0 4px 12px hsl(220 25% 15% / 0.08);
}

.toast-2__icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 24px;
  height: 24px;
  background: var(--danger);
  color: var(--bg);
  border-radius: 50%;
  font-size: var(--font-md);
  font-weight: 700;
  flex-shrink: 0;
  line-height: 1;
}

.toast-2__content {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.toast-2__title {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--fg);
}

.toast-2__message {
  font-size: var(--font-sm);
  color: var(--fg-muted);
  line-height: 1.4;
}
      `}
    />

    <HtmlPreview
      client:visible
      title="3. Info Toast"
      html={`
<div class="toast-3">
  <div class="toast-3__toast">
    <span class="toast-3__icon">i</span>
    <div class="toast-3__content">
      <span class="toast-3__title">Information</span>
      <span class="toast-3__message">A new version is available. Refresh to update.</span>
    </div>
  </div>
</div>
      `}
      css={`
.toast-3 {
  max-width: 400px;
  margin: 0 auto;
}

.toast-3__toast {
  display: flex;
  align-items: flex-start;
  gap: var(--space-sm);
  padding: var(--space-md);
  background: var(--bg);
  border: 1px solid var(--border);
  border-left: 4px solid var(--info);
  border-radius: var(--radius);
  box-shadow: 0 4px 12px hsl(220 25% 15% / 0.08);
}

.toast-3__icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 24px;
  height: 24px;
  background: var(--info);
  color: var(--bg);
  border-radius: 50%;
  font-size: var(--font-sm);
  font-weight: 700;
  font-style: italic;
  flex-shrink: 0;
  line-height: 1;
}

.toast-3__content {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.toast-3__title {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--fg);
}

.toast-3__message {
  font-size: var(--font-sm);
  color: var(--fg-muted);
  line-height: 1.4;
}
      `}
    />

    <HtmlPreview
      client:visible
      title="4. Toast with Action Button"
      html={`
<div class="toast-4">
  <div class="toast-4__toast">
    <div class="toast-4__body">
      <span class="toast-4__message">File moved to trash.</span>
      <div class="toast-4__actions">
        <button class="toast-4__action">Undo</button>
        <button class="toast-4__dismiss">&times;</button>
      </div>
    </div>
  </div>
</div>
      `}
      css={`
.toast-4 {
  max-width: 400px;
  margin: 0 auto;
}

.toast-4__toast {
  background: var(--fg);
  border-radius: var(--radius);
  box-shadow: 0 4px 12px hsl(220 25% 15% / 0.15);
  overflow: hidden;
}

.toast-4__body {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-md);
  padding: var(--space-sm) var(--space-md);
}

.toast-4__message {
  font-size: var(--font-md);
  color: var(--bg);
  flex: 1;
}

.toast-4__actions {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  flex-shrink: 0;
}

.toast-4__action {
  font-family: system-ui, sans-serif;
  font-size: var(--font-sm);
  font-weight: 600;
  color: var(--accent);
  background: none;
  border: none;
  cursor: pointer;
  padding: var(--space-xs);
  border-radius: 4px;
  transition: background 0.15s ease;
}

.toast-4__action:hover {
  background: hsl(220 70% 50% / 0.15);
}

.toast-4__dismiss {
  font-family: system-ui, sans-serif;
  font-size: var(--font-md);
  color: var(--bg-subtle);
  background: none;
  border: none;
  cursor: pointer;
  padding: var(--space-xs);
  border-radius: 4px;
  line-height: 1;
  transition: color 0.15s ease;
}

.toast-4__dismiss:hover {
  color: var(--bg);
}
      `}
    />

  </div>
</BaseLayout>
